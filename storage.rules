rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de gatos — cualquier usuario logueado puede subir
    match /cats/{catId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Documentos de seguimiento — solo el adoptante
    match /tracking/{adoptionId}/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
